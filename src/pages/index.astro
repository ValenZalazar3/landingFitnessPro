---
import Layout from '@/layouts/Layout.astro'
import Hero from '@/components/Hero.astro'
import Projects from '@/components/Projects.astro'
import Services from '@/components/Services.astro'
import Calendly from '@/components/Calendly.astro'
import SectionContainer from '@/components/SectionContainer.astro'
import Steps from '@/components/Steps.astro'
---

<Layout
	title='Lading Fitness Pro'
	description='Somos especializados en hacer páginas web para coach fitness, con nuestras estrategias validadas podrás crecer en tu sector y tener mayores ventas.'
>
	<main class='px-4'>
		<SectionContainer
			class='py-16 md:py-36'
			id='hero'
		>
			<Hero />
		</SectionContainer>
	</main>
	<div class='space-y-10 px-4'>
		<SectionContainer
			class='py-14'
			id='services'
		>
			<Services />
		</SectionContainer>
		<SectionContainer
			class='py-14'
			id='projects'
		>
			<Projects />
		</SectionContainer>
		<SectionContainer
			class='py-14'
			id='steps'
		>
			<Steps />
		</SectionContainer>
		<SectionContainer id='calendly' />
		<Calendly />
	</div>
</Layout>
